# Playlist Lab Server Configuration
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=production
PORT=3001

# Security
SESSION_SECRET=change-this-to-a-random-string-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_PATH=/data/playlist-lab.db

# Logging
LOG_LEVEL=info

# Cache Settings
CACHE_MAX_AGE_HOURS=24

# Background Jobs
# Enable background jobs in development mode (always enabled in production)
# Set to 'true' to enable schedule checker, scraper, and cache cleanup jobs
ENABLE_JOBS=true

# Scraper Schedule (cron format: minute hour day month weekday)
# Default: 2 AM daily
SCRAPER_SCHEDULE=0 2 * * *

# Schedule Checker
# Runs every 10 minutes to check for due schedules
# Set to 'false' to disable (not recommended)
# ENABLE_SCHEDULE_CHECKER=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Plex Configuration (optional)
# PLEX_TOKEN=your-plex-token-here
# PLEX_SERVER_URL=http://your-plex-server:32400

# Spotify Configuration (optional)
# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# SPOTIFY_REDIRECT_URI=http://localhost:3001/api/spotify/callback

# AI Features (optional)
# OPENAI_API_KEY=your-openai-api-key
