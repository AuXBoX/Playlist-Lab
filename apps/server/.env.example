# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Public URL Configuration (for OAuth and reverse proxy support)
# This is the public-facing URL where users access Playlist Lab
# Examples:
#   http://127.0.0.1:3001 (default, local development - use 127.0.0.1 for Spotify compatibility)
#   https://playlist-lab.example.com (reverse proxy with HTTPS)
#   http://192.168.1.100:3001 (LAN access)
# IMPORTANT: Update this if accessing via reverse proxy or remote network
# NOTE: Use 127.0.0.1 instead of localhost for better OAuth compatibility (especially Spotify)
PUBLIC_URL=http://127.0.0.1:3001

# Optional: Override OAuth redirect base URL separately from PUBLIC_URL
# Only set this if your OAuth redirects need a different URL than PUBLIC_URL
# OAUTH_REDIRECT_BASE=https://playlist-lab.example.com

# Database
DATABASE_PATH=./data/playlist-lab.db

# Session
SESSION_SECRET=your-secret-key-change-in-production

# Remote Access / CORS
# Use '*' to allow all origins (recommended for local network access)
# Or specify comma-separated origins: http://localhost:5173,http://192.168.1.x:3001
CORS_ORIGIN=*
# Set to 'true' if behind a reverse proxy (nginx, Caddy, etc.)
TRUST_PROXY=false
# Cookie settings for cross-origin access
# Use 'none' for cross-origin (requires COOKIE_SECURE=true), 'lax' for same-origin
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Logging
LOG_LEVEL=info

# Cache
CACHE_MAX_AGE_HOURS=24

# Background Jobs
SCRAPER_SCHEDULE=0 2 * * *

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5000

# Admin Users (comma-separated Plex user IDs)
ADMIN_PLEX_IDS=

# Spotify OAuth (for playlist preview/import)
# REQUIRED: Create a Spotify app at https://developer.spotify.com/dashboard
# Setup steps:
# 1. Click "Create app"
# 2. Fill in app name and description
# 3. Add BOTH redirect URIs (Spotify treats localhost and 127.0.0.1 as different):
#    - http://localhost:3001/api/spotify/callback
#    - http://127.0.0.1:3001/api/spotify/callback
# 4. Copy your Client ID and Client Secret below
# Note: Use 127.0.0.1 in SPOTIFY_REDIRECT_URI for better compatibility
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback

# YouTube OAuth Configuration (required for YouTube export feature)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Setup steps:
# 1. Create a new project or select existing project
# 2. Enable "YouTube Data API v3" in APIs & Services > Library
# 3. Go to APIs & Services > Credentials
# 4. Click "Create Credentials" > "OAuth client ID"
# 5. Configure OAuth consent screen if prompted (External type for personal use)
# 6. Application type: "Web application"
# 7. Add Authorized redirect URI: http://localhost:3001/api/cross-import/oauth/youtube/callback
# 8. Copy the Client ID and Client Secret below
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/cross-import/oauth/youtube/callback
