# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_PATH=./data/playlist-lab.db

# Session
SESSION_SECRET=your-secret-key-change-in-production

# Remote Access / CORS
# Comma-separated origins, or '*' to allow all (use with caution)
CORS_ORIGIN=http://localhost:5173
# Set to 'true' if behind a reverse proxy (nginx, Caddy, etc.)
TRUST_PROXY=false
# Cookie settings for cross-origin access
# Use 'none' for cross-origin (requires COOKIE_SECURE=true), 'lax' for same-origin
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Logging
LOG_LEVEL=info

# Cache
CACHE_MAX_AGE_HOURS=24

# Background Jobs
SCRAPER_SCHEDULE=0 2 * * *

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Users (comma-separated Plex user IDs)
ADMIN_PLEX_IDS=

# Spotify OAuth (for playlist preview/import)
# REQUIRED: Create a Spotify app at https://developer.spotify.com/dashboard
# 1. Click "Create app"
# 2. Set Redirect URI to: http://localhost:3001/api/spotify/callback
# 3. Copy your Client ID below (no secret needed for implicit grant)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/spotify/callback
